# Find these in your Supabase project: Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# The new publishable key (starts with `sb_publishable_...`).
# Safe to expose to the browser — RLS still gates everything.
# Legacy `anon` JWT keys also work here during the migration window.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR-KEY

# The public site URL (used for magic link redirects).
# Locally: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Web Push (optional — chat alerts when the app is closed) ───────────────
# Generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto:you@example.com or https://your-site.example
VAPID_SUBJECT=mailto:you@example.com

# Same value you configure on the Supabase webhook (see below).
PUSH_MESSAGE_HOOK_SECRET=

# Server-only: used by /api/push/message-hook to read subscriptions & sender name.
SUPABASE_SERVICE_ROLE_KEY=

# After deploy, add a Supabase Database Webhook:
#   Table: public.messages  ·  Events: INSERT
#   HTTP Request URL: https://YOUR-SITE/api/push/message-hook
#   HTTP Headers: Authorization: Bearer <same as PUSH_MESSAGE_HOOK_SECRET>
